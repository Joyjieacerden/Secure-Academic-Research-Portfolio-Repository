# Python virtual environment
.venv/
venv/
ENV/

# Django database
*.sqlite3

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Environment variables
.env

# Static files
staticfiles/

# Security audit logs (contain sensitive event data)
logs/

# SAST / dependency scan reports (may contain vulnerability details)
security/reports/*.json
security/reports/*.txt

# Keep the reports directory itself
!security/reports/.gitkeep
!security/reports/COMPLIANCE_REPORT.md