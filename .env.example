# =============================================================================
# .env.example — Copy to .env and fill in real values
# NEVER commit the real .env to version control
# =============================================================================

# Django core
DJANGO_SECRET_KEY=replace-with-a-strong-random-key-at-least-50-characters
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production; SQLite used locally by default)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudinary (media/PDF storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
